generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  USER
  ADMIN
}

enum ProjectStatus {
  INTAKE
  CUSTOMIZING
  PREVIEWING
  PROVISIONING
  LIVE
  FAILED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentType {
  BUILD
  HOSTING
  REFUND
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ConversationStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum HostingStatus {
  PROVISIONING
  ACTIVE
  SUSPENDED
  CANCELLED
  EJECTED
  TRANSFERRED
}

enum HostingPlan {
  STARTER
  GROWTH
  SCALE
}

enum TransferStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

// ============================================================================
// NEXTAUTH MODELS
// ============================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

// ============================================================================
// USER
// ============================================================================

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String?   @unique
  emailVerified    DateTime?
  image            String?
  stripeCustomerId String?   @unique
  role             UserRole  @default(USER)

  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  conversations Conversation[]
  payments      Payment[]

  @@map("users")
}

// ============================================================================
// INDUSTRY TEMPLATE
// ============================================================================

model IndustryTemplate {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  description   String?  @db.Text
  isActive      Boolean  @default(true)
  version       Int      @default(1)
  templatePath  String   // path to template source files
  features      Json     // what this template includes
  defaultConfig Json     // default brand colors, fonts, etc.
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projects Project[]

  @@map("industry_templates")
}

// ============================================================================
// PROJECT
// ============================================================================

model Project {
  id             String        @id @default(uuid())
  userId         String
  templateId     String?
  name           String        // business name
  status         ProjectStatus @default(INTAKE)
  industryProfile Json?        // extracted profile (services, packages, timezone, brand)
  customizations  Json?        // overrides applied during preview
  previewUrl     String?       // Vercel preview URL
  productionUrl  String?       // live URL after deploy
  githubRepoUrl  String?
  githubRepoName String?
  errorMessage   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  completedAt    DateTime?

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  template         IndustryTemplate? @relation(fields: [templateId], references: [id])
  deployedApp      DeployedApp?
  changeRequests   ChangeRequest[]
  refinementCycles RefinementCycle[]
  conversations    Conversation[]
  payments         Payment[]

  @@index([userId])
  @@index([status])
  @@map("projects")
}

// ============================================================================
// CONVERSATION + MESSAGES
// ============================================================================

model Conversation {
  id                     String             @id @default(cuid())
  projectId              String?
  userId                 String
  sessionId              String             @unique
  status                 ConversationStatus @default(ACTIVE)
  industryClassification String?            // e.g., "coaching", "home_services"
  extractedProfile       Json?              // structured data from conversation
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  project  Project?              @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ConversationMessage[]

  @@index([userId])
  @@index([sessionId])
  @@map("conversations")
}

model ConversationMessage {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String      @db.Text
  metadata       Json?       // structured data like extracted fields
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("conversation_messages")
}

// ============================================================================
// DEPLOYED APP — tracks all provisioned infrastructure
// ============================================================================

model DeployedApp {
  id                     String        @id @default(uuid())
  projectId              String        @unique
  project                Project       @relation(fields: [projectId], references: [id])

  // Neon
  neonProjectId          String?
  neonBranchId           String?
  neonDatabaseUrl        String?       @db.Text
  neonPooledUrl          String?       @db.Text

  // Vercel
  vercelProjectId        String?
  vercelProjectName      String?
  vercelProductionUrl    String?

  // GitHub
  githubRepoFullName     String?
  githubRepoUrl          String?

  // Stripe Connect
  stripeConnectAccountId     String?
  stripeConnectAccountType   String?   @default("standard")
  stripeConnectOnboarded     Boolean   @default(false)
  stripeConnectOnboardingUrl String?

  // Custom Domain
  customDomain           String?
  domainVerified         Boolean       @default(false)

  // Resend
  resendDomainId         String?

  // Hosting
  hostingStatus          HostingStatus @default(PROVISIONING)
  provisioningLog        Json?

  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  subscription           HostingSubscription?
  transfers              TransferRequest[]

  @@index([hostingStatus])
  @@map("deployed_apps")
}

// ============================================================================
// HOSTING SUBSCRIPTION
// ============================================================================

model HostingSubscription {
  id                   String      @id @default(uuid())
  deployedAppId        String      @unique
  deployedApp          DeployedApp @relation(fields: [deployedAppId], references: [id])
  stripeSubscriptionId String      @unique
  stripeCustomerId     String
  plan                 HostingPlan @default(STARTER)
  status               String      @default("active")
  currentPeriodEnd     DateTime
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@map("hosting_subscriptions")
}

// ============================================================================
// TRANSFER REQUEST — eject / ownership transfer
// ============================================================================

model TransferRequest {
  id                    String         @id @default(uuid())
  deployedAppId         String
  deployedApp           DeployedApp    @relation(fields: [deployedAppId], references: [id])
  status                TransferStatus @default(PENDING)

  // Per-service transfer status
  githubTransferred     Boolean        @default(false)
  vercelTransferred     Boolean        @default(false)
  neonTransferred       Boolean        @default(false)
  stripeDisconnected    Boolean        @default(false)

  // Claim URLs
  neonClaimUrl          String?
  githubTransferUrl     String?
  vercelReimportUrl     String?

  // Customer info
  customerGithubUsername String?
  customerEmail          String

  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  completedAt           DateTime?

  @@index([deployedAppId])
  @@index([status])
  @@map("transfer_requests")
}

// ============================================================================
// CHANGE REQUEST — iteration loop
// ============================================================================

model ChangeRequest {
  id            String    @id @default(uuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id])
  userMessage   String
  status        String    @default("PENDING") // PENDING | PROCESSING | COMPLETE | FAILED
  affectedFiles String[]  @default([])
  diffSummary   String?
  deployUrl     String?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  @@index([projectId])
  @@index([status])
  @@map("change_requests")
}

// ============================================================================
// OPENCLAW — refinement cycles + agent evaluations
// ============================================================================

model RefinementCycle {
  id                  String            @id @default(uuid())
  projectId           String
  project             Project           @relation(fields: [projectId], references: [id])
  cycleNumber         Int
  status              String            @default("PENDING")
  synthesizedFeedback String?           @db.Text
  filesRegenerated    String[]          @default([])
  tokensUsed          Int               @default(0)
  executionTimeMs     Int?
  createdAt           DateTime          @default(now())
  completedAt         DateTime?
  evaluations         AgentEvaluation[]

  @@unique([projectId, cycleNumber])
  @@index([projectId])
  @@map("refinement_cycles")
}

model AgentEvaluation {
  id              String          @id @default(uuid())
  cycleId         String
  cycle           RefinementCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  skill           String
  findings        Json
  score           Int?
  rawOutput       String          @db.Text
  tokensUsed      Int             @default(0)
  executionTimeMs Int?
  createdAt       DateTime        @default(now())

  @@index([cycleId])
  @@index([skill])
  @@map("agent_evaluations")
}

// ============================================================================
// PAYMENT
// ============================================================================

model Payment {
  id                    String        @id @default(uuid())
  userId                String
  projectId             String?
  type                  PaymentType
  amount                Int           // in cents
  currency              String        @default("usd")
  status                PaymentStatus @default(PENDING)
  stripeSessionId       String?       @unique
  stripePaymentIntentId String?
  stripeCustomerId      String?
  metadata              Json?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  completedAt           DateTime?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([stripeSessionId])
  @@index([status])
  @@map("payments")
}

// ============================================================================
// CONTACT SUBMISSIONS — FSVC marketing site
// ============================================================================

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@map("contact_submissions")
}
